# 复制本文件为 .env 并填入真实值。.env 已被 git 忽略，勿提交真实密钥。
# 演示阶段可先用 mock（无需任何后端配置）。

# ── Supabase（客户端公钥，M2+）─────────────────────────────
# Project Settings → API 里的 Project URL 与 anon public key
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── AI Provider: mock | doubao | kling ───────────────────────
# 后端 Edge Function 就绪前用 mock；就绪后改 doubao
EXPO_PUBLIC_AI_PROVIDER=mock

# ── 豆包（仅保底；正式走 Edge Function secrets，不放客户端）──
# 真实豆包密钥应配到 Supabase Edge Function secrets，不要填在客户端 .env
EXPO_PUBLIC_DOUBAO_BASE_URL=https://llmapi.paratera.com
EXPO_PUBLIC_DOUBAO_API_KEY=
EXPO_PUBLIC_DOUBAO_MODEL=Doubao-Seedance-1.0-Pro
